#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * secret-scrub-dump — the PHP port's SECRET-SCRUB behavioral dump program for
 * the cross-port differ (porting-sdk/scripts/diff_port_secret_scrub.py).
 *
 * The differ builds the golden per-sentinel classification by driving the
 * python reference through a real RELAY connect + an inbound
 * ``signalwire.authorization.state`` re-auth frame at
 * ``SIGNALWIRE_LOG_LEVEL=debug`` with the fixture sentinels
 * (project=PJ-TESTLEAK / token=PT-TESTLEAK / authorization_state=AENC-TESTLEAK)
 * and observing that NONE appear in the captured debug output — python scrubs,
 * so every golden is ``{leaked: false}``. This program does the identical drive
 * against the PHP SDK, captures the SDK's OWN debug output, and emits
 * per-sentinel ``{"<id>": {"leaked": <bool>}}`` on stdout.
 *
 * A port that logged the raw frame verbatim would surface the sentinel in its
 * captured output → ``leaked: true`` → the differ reds. With Client::scrubFrame
 * masking the credential/authorization_state VALUES at both frame-log sites,
 * every sentinel comes back ``leaked: false``.
 *
 * ## Two-phase design (why)
 *
 * The SDK Logger writes to the real STDERR fd (in CLI it uses the ``\STDERR``
 * constant directly, so an in-process stream-wrapper override is NOT honored).
 * To observe EXACTLY what the SDK emits regardless of how it resolves stderr,
 * this program runs the actual drive in a CHILD invocation of itself
 * (``SW_SS_CHILD=1``) whose stderr is redirected to a pipe. The PARENT reads
 * that pipe (the SDK's real debug output), classifies each sentinel, forwards
 * the child's stderr to the real stderr (so the differ's own subprocess-stderr
 * capture sees the identical bytes), and prints the JSON classification to
 * stdout. The child prints nothing to stdout — only the parent does.
 *
 * Protocol: stdout = ONE JSON object mapping corpus id => {leaked: bool}.
 *
 * Run from the signalwire-php repo root (with a mock_relay reachable via
 * MOCK_RELAY_PORT / MOCK_RELAY_HTTP_PORT, or auto-spawned by the harness):
 *
 *   SIGNALWIRE_LOG_LEVEL=debug php bin/secret-scrub-dump
 *
 * Copyright (c) 2025 SignalWire
 * Licensed under the MIT License.
 */

// ---------------------------------------------------------------------------
// Fixture sentinels — byte-identical to porting-sdk/scripts/secret_scrub_corpus.py.
// ---------------------------------------------------------------------------
const SS_PROJECT             = 'PJ-TESTLEAK';
const SS_TOKEN               = 'PT-TESTLEAK';
const SS_AUTHORIZATION_STATE = 'AENC-TESTLEAK';

/** @var array<string,string> corpus id => sentinel string that must not leak. */
const SS_CORPUS = [
    'project'             => SS_PROJECT,
    'token'               => SS_TOKEN,
    'authorization_state' => SS_AUTHORIZATION_STATE,
];

$isChild = getenv('SW_SS_CHILD') === '1';

if ($isChild) {
    exit(ss_child_drive());
}
exit(ss_parent(dirname(__DIR__)));

/**
 * PARENT: spawn the child drive with stderr captured to a pipe, read the SDK's
 * real debug output, classify each sentinel, forward the child's stderr to the
 * real stderr, and print the JSON classification to stdout.
 */
function ss_parent(string $repoRoot): int
{
    $php = PHP_BINARY ?: 'php';
    $self = __FILE__;

    $env = getenv();
    $env['SW_SS_CHILD'] = '1';
    $env['SIGNALWIRE_LOG_LEVEL'] = 'debug';

    $descriptors = [
        0 => ['pipe', 'r'],
        1 => ['pipe', 'w'], // child stdout (unused; kept clean)
        2 => ['pipe', 'w'], // child stderr — the SDK's debug log lands here
    ];
    $proc = proc_open([$php, $self], $descriptors, $pipes, $repoRoot, $env);
    if (!is_resource($proc)) {
        fwrite(STDERR, "secret-scrub-dump: failed to spawn child drive\n");
        return 1;
    }
    fclose($pipes[0]);
    $childOut = stream_get_contents($pipes[1]);
    fclose($pipes[1]);
    $childErr = stream_get_contents($pipes[2]);
    fclose($pipes[2]);
    proc_close($proc);

    // Forward the child's stderr (the SDK debug log) so the differ's own
    // subprocess-stderr capture sees the identical output.
    if ($childErr !== '' && $childErr !== false) {
        fwrite(STDERR, $childErr);
    }
    if ($childOut !== '' && $childOut !== false) {
        fwrite(STDERR, $childOut);
    }

    $log = (string) $childErr;
    $out = [];
    foreach (SS_CORPUS as $id => $sentinel) {
        $out[$id] = ['leaked' => str_contains($log, $sentinel)];
    }
    fwrite(STDOUT, json_encode($out, JSON_UNESCAPED_SLASHES) . "\n");
    return 0;
}

/**
 * CHILD: drive a real RELAY connect (sentinel creds) + an inbound
 * authorization.state event (sentinel blob) at debug. All SDK output goes to
 * stderr; stdout stays empty. The parent classifies from our stderr.
 */
function ss_child_drive(): int
{
    // Any stray stdout would corrupt the parent's stdout; push it to stderr.
    ob_start(function (string $chunk): string {
        if ($chunk !== '') {
            fwrite(STDERR, $chunk);
        }
        return '';
    }, 1);

    $autoload = dirname(__DIR__) . '/vendor/autoload.php';
    if (!is_file($autoload)) {
        fwrite(STDERR, "secret-scrub-dump: vendor/autoload.php not found; run composer install\n");
        return 1;
    }
    require_once $autoload;
    $mockTestFile = dirname(__DIR__) . '/tests/Relay/MockTest.php';
    if (is_file($mockTestFile)) {
        require_once $mockTestFile;
    }

    $shared = \SignalWire\Tests\Relay\MockTest::harness();

    // Connect with the sentinel project/token so the outbound signalwire.connect
    // frame (the >> log site) actually carries them.
    $client = new \SignalWire\Relay\Client([
        'project'  => SS_PROJECT,
        'token'    => SS_TOKEN,
        'host'     => $shared->relayHost(),
        'scheme'   => 'ws',
        'contexts' => ['default'],
    ]);
    $client->connect();

    try {
        $mock = new \SignalWire\Tests\Relay\RelayHarness(
            $shared->httpUrl(),
            $shared->wsPort(),
            $shared->httpPort()
        );
        $mock->scopeTo((string) $client->sessionId);

        // Push an inbound re-auth blob (the << log site's payload).
        $mock->push([
            'jsonrpc' => '2.0',
            'method'  => 'signalwire.event',
            'params'  => [
                'event_type' => 'signalwire.authorization.state',
                'params'     => ['authorization_state' => SS_AUTHORIZATION_STATE],
            ],
        ]);

        // Pump the read loop so the pushed frame is received + logged.
        \SignalWire\Tests\Relay\MockTest::pumpFor($client, 400);
    } finally {
        try {
            $client->disconnect();
        } catch (\Throwable) {
            // best-effort teardown
        }
    }

    while (ob_get_level() > 0) {
        ob_end_clean();
    }
    return 0;
}
