#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * swaig-test - CLI tool for testing SWAIG agent endpoints
 *
 * Usage:
 *   swaig-test --url http://user:pass@host:port/route --dump-swml
 *   swaig-test --url http://user:pass@host:port/route --list-tools
 *   swaig-test --url http://user:pass@host:port/route --exec tool_name --param key=value
 *   swaig-test --file path/to/example.php --list-tools
 *
 * Copyright (c) 2025 SignalWire
 * Licensed under the MIT License.
 */

$VERSION = '1.0.0';

// ============================================================
//  CLI Option Parsing
// ============================================================

$url       = null;
$file      = null;
$dumpSwml  = false;
$listTools = false;
$execName  = null;
$params    = [];
$raw       = false;
$verbose   = false;
$help      = false;

$args = array_slice($argv, 1);
$i = 0;
$count = count($args);

while ($i < $count) {
    $arg = $args[$i];

    switch ($arg) {
        case '--url':
            $i++;
            if ($i >= $count) {
                fwrite(STDERR, "Error: --url requires a value\n");
                exit(1);
            }
            $url = $args[$i];
            break;

        case '--file':
        case '--example':
            $i++;
            if ($i >= $count) {
                fwrite(STDERR, "Error: {$arg} requires a path\n");
                exit(1);
            }
            $file = $args[$i];
            break;

        case '--dump-swml':
            $dumpSwml = true;
            break;

        case '--list-tools':
            $listTools = true;
            break;

        case '--exec':
            $i++;
            if ($i >= $count) {
                fwrite(STDERR, "Error: --exec requires a tool name\n");
                exit(1);
            }
            $execName = $args[$i];
            break;

        case '--param':
            $i++;
            if ($i >= $count) {
                fwrite(STDERR, "Error: --param requires a key=value argument\n");
                exit(1);
            }
            $params[] = $args[$i];
            break;

        case '--raw':
            $raw = true;
            break;

        case '--verbose':
            $verbose = true;
            break;

        case '--help':
        case '-h':
            $help = true;
            break;

        default:
            fwrite(STDERR, "Error: Unknown option '{$arg}'\n\n");
            usageExit(1);
    }

    $i++;
}

// ============================================================
//  Validation
// ============================================================

if ($help) {
    usageExit(0);
}

if ($url !== null && $file !== null) {
    fwrite(STDERR, "Error: --url and --file are mutually exclusive\n\n");
    usageExit(1);
}

if ($url === null && $file === null) {
    fwrite(STDERR, "Error: one of --url or --file is required\n\n");
    usageExit(1);
}

if (!$dumpSwml && !$listTools && $execName === null) {
    fwrite(STDERR, "Error: one of --dump-swml, --list-tools, or --exec NAME is required\n\n");
    usageExit(1);
}

// ============================================================
//  File-Mode Dispatch (no HTTP — load example in-process)
// ============================================================

if ($file !== null) {
    if ($dumpSwml || $execName !== null) {
        fwrite(STDERR, "Error: --file currently supports --list-tools only (got "
            . ($dumpSwml ? '--dump-swml' : '--exec') . ")\n");
        exit(1);
    }
    doListToolsFromFile($file);
    exit(0);
}

// ============================================================
//  Parse URL and Extract Auth
// ============================================================

$parsedUrl = parseUrlWithAuth($url);
$baseUrl   = $parsedUrl['base_url'];
$authUser  = $parsedUrl['user'];
$authPass  = $parsedUrl['pass'];

// ============================================================
//  Execute the Requested Operation
// ============================================================

if ($dumpSwml) {
    doDumpSwml();
} elseif ($listTools) {
    doListTools();
} elseif ($execName !== null) {
    doExec($execName);
}

exit(0);

// ============================================================
//  Operations
// ============================================================

function doDumpSwml(): void
{
    global $baseUrl, $raw, $verbose;

    $response = httpGet($baseUrl);

    if ($raw) {
        echo $response;
        if (substr($response, -1) !== "\n") {
            echo "\n";
        }
    } else {
        $data = json_decode($response, true);
        if ($data === null && json_last_error() !== JSON_ERROR_NONE) {
            fwrite(STDERR, "Error: Failed to parse JSON response: " . json_last_error_msg() . "\n");
            exit(1);
        }
        echo json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
        echo "\n";
    }
}

function doListTools(): void
{
    global $baseUrl, $raw;

    $response = httpGet($baseUrl);
    $data = json_decode($response, true);
    if ($data === null && json_last_error() !== JSON_ERROR_NONE) {
        fwrite(STDERR, "Error: Failed to parse JSON response: " . json_last_error_msg() . "\n");
        exit(1);
    }

    // Extract SWAIG functions from the SWML document
    $functions = [];

    if (isset($data['sections']) && is_array($data['sections'])) {
        foreach ($data['sections'] as $sectionName => $verbs) {
            if (!is_array($verbs)) {
                continue;
            }
            foreach ($verbs as $verb) {
                if (is_array($verb) && isset($verb['ai'])) {
                    $ai = $verb['ai'];
                    if (isset($ai['SWAIG']['functions']) && is_array($ai['SWAIG']['functions'])) {
                        $functions = array_merge($functions, $ai['SWAIG']['functions']);
                    }
                }
            }
        }
    }

    if (empty($functions)) {
        echo "No SWAIG functions found.\n";
        return;
    }

    if ($raw) {
        foreach ($functions as $f) {
            $name = $f['function'] ?? 'unnamed';
            $desc = $f['description'] ?? $f['purpose'] ?? '';
            echo "{$name}\t{$desc}\n";
        }
    } else {
        $count = count($functions);
        echo "Found {$count} SWAIG function(s):\n\n";

        foreach ($functions as $f) {
            $name = $f['function'] ?? 'unnamed';
            $desc = $f['description'] ?? $f['purpose'] ?? '(no description)';
            printf("  %-30s %s\n", $name, $desc);

            // Show parameters if any
            $paramsSchema = $f['parameters'] ?? $f['argument'] ?? null;
            if ($paramsSchema !== null && isset($paramsSchema['properties'])) {
                $props    = $paramsSchema['properties'];
                $required = $paramsSchema['required'] ?? [];
                $requiredMap = array_flip($required);

                ksort($props);
                foreach ($props as $pname => $pdef) {
                    $ptype = $pdef['type'] ?? 'any';
                    $pdesc = $pdef['description'] ?? '';
                    $reqMarker = isset($requiredMap[$pname]) ? '*' : ' ';
                    printf("    %s %-20s %-10s %s\n", $reqMarker, $pname, "({$ptype})", $pdesc);
                }
            }

            echo "\n";
        }
    }
}

/**
 * Load a PHP example/script in-process and list its registered SWAIG tools by
 * walking the SWML\Service runtime registry — no HTTP, no server.
 *
 * The script must guard its `serve()` / `run()` call with a "is this script
 * being run directly?" check (see examples/SwmlServiceSwaigStandalone.php),
 * otherwise requiring it would start a server. This function does NOT start
 * any listener; it just loads the file, finds the most-recently-declared
 * SWML\Service subclass instance (or builds one), and reflects on its
 * private `$tools` array.
 */
function doListToolsFromFile(string $path): void
{
    global $raw;

    if (!is_file($path)) {
        fwrite(STDERR, "Error: file not found: {$path}\n");
        exit(1);
    }
    $real = realpath($path);
    if ($real === false) {
        fwrite(STDERR, "Error: could not resolve path: {$path}\n");
        exit(1);
    }

    // Make sure the autoloader is active. The script may also require it,
    // but loading ourselves means we don't depend on the script doing it.
    $autoload = dirname(__DIR__) . '/vendor/autoload.php';
    if (is_file($autoload)) {
        require_once $autoload;
    }

    $beforeClasses = get_declared_classes();
    $beforeFunctions = get_defined_functions()['user'];

    // Snapshot $GLOBALS so we can find any Service instance the example
    // assigned at top level (rare; most examples build inside a function).
    $beforeGlobals = array_keys($GLOBALS);

    // Require the example. Top-level `if (run-directly) { ... }` blocks
    // suppress server start; defineTool() calls inside builder functions
    // are skipped until we invoke the builder ourselves below.
    try {
        require_once $real;
    } catch (\Throwable $e) {
        fwrite(STDERR, "Error: failed to require {$path}: {$e->getMessage()}\n");
        exit(1);
    }

    /** @var \SignalWire\SWML\Service|null $service */
    $service = null;

    // 1. Did `require_once` itself create a Service in globals? Unusual,
    //    but cheap to check.
    foreach (array_diff(array_keys($GLOBALS), $beforeGlobals) as $name) {
        $val = $GLOBALS[$name] ?? null;
        if ($val instanceof \SignalWire\SWML\Service) {
            $service = $val;
            break;
        }
    }

    // 2. Otherwise look for a builder function the example declared and
    //    invoke it. Examples in this repo follow the convention
    //    `buildXxxService()`. We also accept any zero-arg user function
    //    that returns a Service.
    if ($service === null) {
        $afterFunctions = get_defined_functions()['user'];
        $newFunctions   = array_values(array_diff($afterFunctions, $beforeFunctions));
        // Prefer obvious builder names first.
        usort($newFunctions, function ($a, $b) {
            $aHit = (int) (stripos($a, 'build') !== false);
            $bHit = (int) (stripos($b, 'build') !== false);
            return $bHit <=> $aHit;
        });
        foreach ($newFunctions as $fn) {
            try {
                $reflect = new \ReflectionFunction($fn);
            } catch (\Throwable) {
                continue;
            }
            // Skip anything that requires arguments without a default; we
            // only call zero-arg-safe functions.
            $needsArg = false;
            foreach ($reflect->getParameters() as $p) {
                if (!$p->isOptional()) {
                    $needsArg = true;
                    break;
                }
            }
            if ($needsArg) {
                continue;
            }
            try {
                $candidate = $reflect->invoke();
            } catch (\Throwable) {
                continue;
            }
            if ($candidate instanceof \SignalWire\SWML\Service) {
                $service = $candidate;
                break;
            }
        }
    }

    // 3. Last resort — try to instantiate the most-recently-declared
    //    SWML\Service subclass (other than Service / AgentBase themselves).
    if ($service === null) {
        $afterClasses = get_declared_classes();
        $newClasses   = array_diff($afterClasses, $beforeClasses);
        $candidates   = [];
        foreach ($newClasses as $cls) {
            if (!is_subclass_of($cls, \SignalWire\SWML\Service::class)) {
                continue;
            }
            if ($cls === \SignalWire\Agent\AgentBase::class) {
                continue;
            }
            $candidates[] = $cls;
        }
        // Most-recently-declared wins.
        $candidates = array_reverse($candidates);
        foreach ($candidates as $cls) {
            try {
                $service = new $cls();
                break;
            } catch (\Throwable) {
                // Constructor needs args — skip this one.
                continue;
            }
        }
    }

    if (!$service instanceof \SignalWire\SWML\Service) {
        fwrite(STDERR, "Error: could not locate a SignalWire\\SWML\\Service "
            . "instance in {$path}. The example must declare a build*Service() "
            . "function returning a Service, or assign one to a global.\n");
        exit(1);
    }

    // Walk the runtime tool registry via reflection. The property is
    // `protected $tools` on SWML\Service.
    try {
        $rp = new \ReflectionProperty(\SignalWire\SWML\Service::class, 'tools');
        $rp->setAccessible(true);
        $tools = $rp->getValue($service);
    } catch (\Throwable $e) {
        fwrite(STDERR, "Error: could not read tool registry: {$e->getMessage()}\n");
        exit(1);
    }

    if (!is_array($tools) || empty($tools)) {
        echo "No SWAIG functions found.\n";
        return;
    }

    if ($raw) {
        foreach ($tools as $t) {
            $name = $t['function'] ?? 'unnamed';
            $desc = $t['purpose'] ?? $t['description'] ?? '';
            echo "{$name}\t{$desc}\n";
        }
        return;
    }

    $count = count($tools);
    echo "Found {$count} SWAIG function(s):\n\n";

    foreach ($tools as $t) {
        $name = $t['function'] ?? 'unnamed';
        $desc = $t['purpose'] ?? $t['description'] ?? '(no description)';
        printf("  %-30s %s\n", $name, $desc);

        // Tool definitions on Service use 'argument' for the schema (with
        // 'properties'). Some raw definitions may use 'parameters' instead.
        $paramsSchema = $t['argument'] ?? $t['parameters'] ?? null;
        if (is_array($paramsSchema) && isset($paramsSchema['properties']) && is_array($paramsSchema['properties'])) {
            $props    = $paramsSchema['properties'];
            $required = $paramsSchema['required'] ?? [];
            $requiredMap = is_array($required) ? array_flip($required) : [];

            ksort($props);
            foreach ($props as $pname => $pdef) {
                $ptype = is_array($pdef) ? ($pdef['type'] ?? 'any') : 'any';
                $pdesc = is_array($pdef) ? ($pdef['description'] ?? '') : '';
                $reqMarker = isset($requiredMap[$pname]) ? '*' : ' ';
                printf("    %s %-20s %-10s %s\n", $reqMarker, $pname, "({$ptype})", $pdesc);
            }
        }
        echo "\n";
    }
}

function doExec(string $funcName): void
{
    global $baseUrl, $params, $raw, $verbose;

    // Parse --param key=value pairs
    $parsedArgs = [];
    foreach ($params as $p) {
        $eqPos = strpos($p, '=');
        if ($eqPos === false) {
            fwrite(STDERR, "Error: Invalid --param format '{$p}'. Use key=value\n");
            exit(1);
        }
        $key = substr($p, 0, $eqPos);
        $val = substr($p, $eqPos + 1);
        $parsedArgs[$key] = $val;
    }

    $swaigUrl = rtrim($baseUrl, '/') . '/swaig';

    $payload = [
        'function' => $funcName,
        'argument' => [
            'parsed' => [$parsedArgs],
        ],
    ];

    $jsonBody = json_encode($payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);

    if ($verbose) {
        fwrite(STDERR, ">>> POST {$swaigUrl}\n");
        fwrite(STDERR, ">>> Body: {$jsonBody}\n");
    }

    $response = httpPost($swaigUrl, $jsonBody);

    if ($verbose) {
        fwrite(STDERR, "<<< Body: {$response}\n");
    }

    if ($raw) {
        echo $response;
        if (substr($response, -1) !== "\n") {
            echo "\n";
        }
    } else {
        $data = json_decode($response, true);
        if ($data === null && json_last_error() !== JSON_ERROR_NONE) {
            echo $response;
            if (substr($response, -1) !== "\n") {
                echo "\n";
            }
        } else {
            echo json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
            echo "\n";
        }
    }
}

// ============================================================
//  URL Parsing
// ============================================================

/**
 * Parse a URL with optional embedded auth (http://user:pass@host:port/path).
 *
 * @return array{base_url: string, user: string|null, pass: string|null}
 */
function parseUrlWithAuth(string $url): array
{
    $parsed = parse_url($url);

    if ($parsed === false) {
        fwrite(STDERR, "Error: Invalid URL '{$url}'\n");
        exit(1);
    }

    $user = $parsed['user'] ?? null;
    $pass = $parsed['pass'] ?? null;

    // Rebuild the URL without credentials
    $scheme = $parsed['scheme'] ?? 'http';
    $host   = $parsed['host'] ?? 'localhost';
    $port   = isset($parsed['port']) ? ':' . $parsed['port'] : '';
    $path   = $parsed['path'] ?? '/';

    // Strip trailing slash for the base URL (unless root)
    $baseUrl = "{$scheme}://{$host}{$port}{$path}";
    $baseUrl = rtrim($baseUrl, '/');

    // Ensure non-empty base URL
    if ($baseUrl === "{$scheme}://{$host}{$port}") {
        $baseUrl .= '';
    }

    return [
        'base_url' => $baseUrl,
        'user'     => $user,
        'pass'     => $pass,
    ];
}

// ============================================================
//  CLI Param Parsing (exposed for testing)
// ============================================================

/**
 * Parse a KEY=VALUE string into [key, value].
 *
 * @return array{string, string}|null Returns null if the format is invalid.
 */
function parseParam(string $param): ?array
{
    $eqPos = strpos($param, '=');
    if ($eqPos === false) {
        return null;
    }
    return [
        substr($param, 0, $eqPos),
        substr($param, $eqPos + 1),
    ];
}

// ============================================================
//  HTTP Helpers
// ============================================================

function buildAuthHeaders(): array
{
    global $authUser, $authPass;

    $headers = [];
    if ($authUser !== null && $authPass !== null) {
        $encoded = base64_encode("{$authUser}:{$authPass}");
        $headers[] = "Authorization: Basic {$encoded}";
    }
    return $headers;
}

function httpGet(string $targetUrl): string
{
    global $verbose;

    if ($verbose) {
        fwrite(STDERR, ">>> GET {$targetUrl}\n");
    }

    $authHeaders = buildAuthHeaders();
    $headerString = implode("\r\n", $authHeaders);

    $context = stream_context_create([
        'http' => [
            'method'  => 'GET',
            'header'  => $headerString,
            'timeout' => 30,
            'ignore_errors' => true,
        ],
    ]);

    $response = @file_get_contents($targetUrl, false, $context);

    if ($response === false) {
        fwrite(STDERR, "Error: Failed to connect to {$targetUrl}\n");
        exit(1);
    }

    // Check HTTP status from response headers
    $statusCode = 0;
    if (isset($http_response_header) && is_array($http_response_header)) {
        foreach ($http_response_header as $header) {
            if (preg_match('#^HTTP/\S+\s+(\d+)#', $header, $m)) {
                $statusCode = (int) $m[1];
            }
        }
    }

    if ($verbose && $statusCode > 0) {
        fwrite(STDERR, "<<< Status: {$statusCode}\n");
    }

    if ($statusCode >= 400) {
        fwrite(STDERR, "Error: HTTP {$statusCode}\n{$response}\n");
        exit(1);
    }

    return $response;
}

function httpPost(string $targetUrl, string $body): string
{
    global $verbose;

    $authHeaders = buildAuthHeaders();
    $authHeaders[] = 'Content-Type: application/json';
    $headerString = implode("\r\n", $authHeaders);

    $context = stream_context_create([
        'http' => [
            'method'  => 'POST',
            'header'  => $headerString,
            'content' => $body,
            'timeout' => 30,
            'ignore_errors' => true,
        ],
    ]);

    $response = @file_get_contents($targetUrl, false, $context);

    if ($response === false) {
        fwrite(STDERR, "Error: Failed to connect to {$targetUrl}\n");
        exit(1);
    }

    // Check HTTP status from response headers
    $statusCode = 0;
    if (isset($http_response_header) && is_array($http_response_header)) {
        foreach ($http_response_header as $header) {
            if (preg_match('#^HTTP/\S+\s+(\d+)#', $header, $m)) {
                $statusCode = (int) $m[1];
            }
        }
    }

    if ($verbose && $statusCode > 0) {
        fwrite(STDERR, "<<< Status: {$statusCode}\n");
    }

    if ($statusCode >= 400) {
        fwrite(STDERR, "Error: HTTP {$statusCode}\n{$response}\n");
        exit(1);
    }

    return $response;
}

// ============================================================
//  Usage
// ============================================================

function usageExit(int $code = 1): never
{
    $text = <<<'USAGE'
swaig-test - CLI tool for testing SWAIG agent endpoints

Usage:
  swaig-test --url URL  [OPTIONS]
  swaig-test --file PATH --list-tools

Options:
  --url URL           Agent URL with embedded auth (http://user:pass@host:port/route)
  --file PATH         Load a PHP example in-process and read the runtime SWAIG
                      tool registry. Mutually exclusive with --url. Use this for
                      SWMLService-only examples that have no <ai> verb. The
                      script must guard its serve()/run() call with a
                      "is this script being run directly?" check.
  --example PATH      Alias for --file.
  --dump-swml         Fetch and display the SWML document (URL mode only)
  --list-tools        List available SWAIG functions
  --exec NAME         Execute a SWAIG function by name (URL mode only)
  --param key=value   Parameter for --exec (repeatable)
  --raw               Output compact JSON (no pretty-printing)
  --verbose           Show request/response details on stderr
  --help, -h          Show this help message

Examples:
  swaig-test --url http://user:pass@localhost:3000/ --dump-swml
  swaig-test --url http://user:pass@localhost:3000/ --list-tools
  swaig-test --url http://user:pass@localhost:3000/ --exec get_weather --param location=London
  swaig-test --url http://user:pass@localhost:3000/ --exec get_weather --param location=London --raw
  swaig-test --file examples/SwmlServiceSwaigStandalone.php --list-tools

USAGE;

    fwrite(STDERR, $text);
    exit($code);
}
