{
    "name": "signalwire/sdk",
    "description": "SignalWire AI Agents SDK for PHP",
    "version": "1.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["signalwire", "ai", "agents", "swml", "swaig", "voip", "telephony"],
    "homepage": "https://github.com/signalwire/signalwire-php",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "phrity/websocket": "^3.7",
        "workerman/workerman": "^5.2"
    },
    "require-dev": {
        "brianium/paratest": "^7",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SignalWire\\": "src/SignalWire/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SignalWire\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/swaig-test"
    ],
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test:verbose": "phpunit --configuration phpunit.xml --testdox --display-deprecations --display-phpunit-deprecations"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
