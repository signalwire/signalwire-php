{
    "name": "signalwire/sdk",
    "description": "SignalWire AI Agents SDK for PHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["signalwire", "ai", "agents", "swml", "swaig", "voip", "telephony"],
    "homepage": "https://github.com/signalwire/signalwire-php",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SignalWire\\": "src/SignalWire/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SignalWire\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/swaig-test"
    ],
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test:verbose": "phpunit --configuration phpunit.xml --verbose"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
